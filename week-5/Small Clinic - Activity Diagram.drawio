<mxfile host="app.diagrams.net" agent="Claude" pages="1">
  <diagram id="AD_SmallClinic" name="Small Clinic - Patient Visit">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" value="Activity Diagram — Small Clinic Patient Visit Workflow" vertex="1">
          <mxGeometry x="200" y="10" width="900" height="36" as="geometry" />
        </mxCell>

        <!-- Swimlane container -->
        <mxCell id="pool" parent="1" style="shape=pool;startSize=30;horizontal=1;childLayout=stackLayout;horizontalStack=1;resizeParent=1;resizeParent=1;collapsible=0;marginBottom=0;swimlaneHead=0;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;fontStyle=1;" value="Small Clinic Patient Visit" vertex="1">
          <mxGeometry x="40" y="60" width="1380" height="980" as="geometry" />
        </mxCell>

        <!-- Swimlane: Patient -->
        <mxCell id="lane_patient" parent="pool" style="swimlane;startSize=30;horizontal=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" value="Patient" vertex="1">
          <mxGeometry x="0" y="0" width="276" height="980" as="geometry" />
        </mxCell>

        <!-- Swimlane: Receptionist -->
        <mxCell id="lane_recept" parent="pool" style="swimlane;startSize=30;horizontal=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" value="Receptionist" vertex="1">
          <mxGeometry x="276" y="0" width="276" height="980" as="geometry" />
        </mxCell>

        <!-- Swimlane: Nurse -->
        <mxCell id="lane_nurse" parent="pool" style="swimlane;startSize=30;horizontal=0;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" value="Nurse" vertex="1">
          <mxGeometry x="552" y="0" width="276" height="980" as="geometry" />
        </mxCell>

        <!-- Swimlane: Doctor -->
        <mxCell id="lane_doctor" parent="pool" style="swimlane;startSize=30;horizontal=0;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" value="Doctor" vertex="1">
          <mxGeometry x="828" y="0" width="276" height="980" as="geometry" />
        </mxCell>

        <!-- Swimlane: Pharmacy -->
        <mxCell id="lane_pharmacy" parent="pool" style="swimlane;startSize=30;horizontal=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" value="Pharmacy / Lab" vertex="1">
          <mxGeometry x="1104" y="0" width="276" height="980" as="geometry" />
        </mxCell>

        <!-- ===== START NODE ===== -->
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry x="178" y="100" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- ===== PATIENT LANE ===== -->
        <mxCell id="arrive" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Patient Arrives at Clinic" vertex="1">
          <mxGeometry x="93" y="155" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="fill_form" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Fill Registration Form" vertex="1">
          <mxGeometry x="93" y="255" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="wait_nurse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Wait in Waiting Room" vertex="1">
          <mxGeometry x="93" y="470" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="patient_consult" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Describe Symptoms to Doctor" vertex="1">
          <mxGeometry x="93" y="650" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="collect_rx" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Collect Prescription / Test Results" vertex="1">
          <mxGeometry x="1143" y="830" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="pay_leave" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="Pay Bill &amp; Leave" vertex="1">
          <mxGeometry x="93" y="900" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- ===== RECEPTIONIST LANE ===== -->
        <mxCell id="check_appt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="Check Appointment / Walk-in" vertex="1">
          <mxGeometry x="369" y="155" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="dec_appt" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="Appointment?" vertex="1">
          <mxGeometry x="384" y="235" width="140" height="70" as="geometry" />
        </mxCell>

        <mxCell id="create_record" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="Create / Update Patient Record" vertex="1">
          <mxGeometry x="369" y="340" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="assign_queue" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="Assign Queue Number &amp; Notify Nurse" vertex="1">
          <mxGeometry x="369" y="420" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="gen_invoice" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="Generate Invoice" vertex="1">
          <mxGeometry x="369" y="880" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- ===== NURSE LANE ===== -->
        <mxCell id="call_patient" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="Call Patient" vertex="1">
          <mxGeometry x="645" y="500" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="take_vitals" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="Record Vitals&#xa;(BP, Temp, Weight, Height)" vertex="1">
          <mxGeometry x="645" y="575" width="170" height="54" as="geometry" />
        </mxCell>

        <mxCell id="escort" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="Escort Patient to Consultation Room" vertex="1">
          <mxGeometry x="645" y="650" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- ===== DOCTOR LANE ===== -->
        <mxCell id="review_rec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Review Patient Record &amp; Vitals" vertex="1">
          <mxGeometry x="921" y="650" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="examine" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Examine Patient" vertex="1">
          <mxGeometry x="921" y="720" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="dec_diag" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Tests Needed?" vertex="1">
          <mxGeometry x="936" y="790" width="140" height="70" as="geometry" />
        </mxCell>

        <mxCell id="write_rx" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Write Prescription &amp; Treatment Plan" vertex="1">
          <mxGeometry x="921" y="890" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="order_tests" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Order Lab / Diagnostic Tests" vertex="1">
          <mxGeometry x="1197" y="790" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- ===== PHARMACY / LAB LANE ===== -->
        <mxCell id="dispense" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="Dispense Medication" vertex="1">
          <mxGeometry x="1197" y="650" width="170" height="44" as="geometry" />
        </mxCell>

        <mxCell id="run_tests" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="Run Tests &amp; Prepare Results" vertex="1">
          <mxGeometry x="1197" y="860" width="170" height="44" as="geometry" />
        </mxCell>

        <!-- ===== END NODE ===== -->
        <mxCell id="end" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=3;" value="" vertex="1">
          <mxGeometry x="178" y="960" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="end_outer" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=none;strokeColor=#000000;strokeWidth=3;" value="" vertex="1">
          <mxGeometry x="172" y="954" width="42" height="42" as="geometry" />
        </mxCell>

        <!-- ===== EDGES ===== -->
        <!-- Start -> Arrive -->
        <mxCell id="e1" edge="1" parent="1" source="start" target="arrive" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrive -> Check Appt -->
        <mxCell id="e2" edge="1" parent="1" source="arrive" target="check_appt" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Check Appt -> Decision -->
        <mxCell id="e3" edge="1" parent="1" source="check_appt" target="dec_appt" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Yes -> Fill Form -->
        <mxCell id="e4" edge="1" parent="1" source="dec_appt" target="fill_form" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;" value="No">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="340" y="270" /><mxPoint x="178" y="270" /></Array></mxGeometry>
        </mxCell>

        <!-- Decision Yes -> Create Record directly -->
        <mxCell id="e4b" edge="1" parent="1" source="dec_appt" target="create_record" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;" value="Yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Fill Form -> Create Record -->
        <mxCell id="e5" edge="1" parent="1" source="fill_form" target="create_record" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="178" y="310" /><mxPoint x="454" y="310" /></Array></mxGeometry>
        </mxCell>

        <!-- Create Record -> Assign Queue -->
        <mxCell id="e6" edge="1" parent="1" source="create_record" target="assign_queue" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Assign Queue -> Wait -->
        <mxCell id="e7" edge="1" parent="1" source="assign_queue" target="wait_nurse" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="454" y="465" /><mxPoint x="178" y="465" /></Array></mxGeometry>
        </mxCell>

        <!-- Assign Queue -> Call Patient -->
        <mxCell id="e8" edge="1" parent="1" source="assign_queue" target="call_patient" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="454" y="465" /><mxPoint x="730" y="465" /></Array></mxGeometry>
        </mxCell>

        <!-- Call Patient -> Take Vitals -->
        <mxCell id="e9" edge="1" parent="1" source="call_patient" target="take_vitals" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Take Vitals -> Escort -->
        <mxCell id="e10" edge="1" parent="1" source="take_vitals" target="escort" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Escort -> Patient Consult (cross-lane) -->
        <mxCell id="e11" edge="1" parent="1" source="escort" target="patient_consult" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="730" y="672" /><mxPoint x="178" y="672" /></Array></mxGeometry>
        </mxCell>

        <!-- Escort -> Review Record -->
        <mxCell id="e12" edge="1" parent="1" source="escort" target="review_rec" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="730" y="672" /><mxPoint x="1006" y="672" /></Array></mxGeometry>
        </mxCell>

        <!-- Review Record -> Examine -->
        <mxCell id="e13" edge="1" parent="1" source="review_rec" target="examine" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Examine -> Decision -->
        <mxCell id="e14" edge="1" parent="1" source="examine" target="dec_diag" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision No -> Write Rx -->
        <mxCell id="e15" edge="1" parent="1" source="dec_diag" target="write_rx" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;" value="No">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Yes -> Order Tests -->
        <mxCell id="e16" edge="1" parent="1" source="dec_diag" target="order_tests" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;" value="Yes">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1076" y="825" /><mxPoint x="1282" y="825" /></Array></mxGeometry>
        </mxCell>

        <!-- Order Tests -> Run Tests -->
        <mxCell id="e17" edge="1" parent="1" source="order_tests" target="run_tests" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Run Tests -> Write Rx (loop back) -->
        <mxCell id="e18" edge="1" parent="1" source="run_tests" target="write_rx" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;dashed=1;dashPattern=6 4;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1282" y="920" /><mxPoint x="1006" y="920" /></Array></mxGeometry>
        </mxCell>

        <!-- Write Rx -> Dispense -->
        <mxCell id="e19" edge="1" parent="1" source="write_rx" target="dispense" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1006" y="912" /><mxPoint x="1006" y="672" /><mxPoint x="1282" y="672" /></Array></mxGeometry>
        </mxCell>

        <!-- Dispense -> Collect -->
        <mxCell id="e20" edge="1" parent="1" source="dispense" target="collect_rx" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Collect -> Generate Invoice -->
        <mxCell id="e21" edge="1" parent="1" source="collect_rx" target="gen_invoice" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1282" y="865" /><mxPoint x="454" y="865" /></Array></mxGeometry>
        </mxCell>

        <!-- Generate Invoice -> Pay & Leave -->
        <mxCell id="e22" edge="1" parent="1" source="gen_invoice" target="pay_leave" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="454" y="902" /><mxPoint x="178" y="902" /></Array></mxGeometry>
        </mxCell>

        <!-- Pay & Leave -> End -->
        <mxCell id="e23" edge="1" parent="1" source="pay_leave" target="end" style="html=1;rounded=1;strokeColor=#333333;endArrow=block;endFill=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== DESCRIPTION PANEL ===== -->
        <mxCell id="desc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#90a4ae;align=left;verticalAlign=top;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontSize=11;fontColor=#263238;" value="&lt;b style='font-size:13px'&gt;Diagram Description&lt;/b&gt;&lt;br&gt;&lt;div style='margin-top:6px;line-height:1.5'&gt;This activity diagram models the end-to-end patient visit workflow for a small clinic. The diagram is divided into five swimlanes representing the key actors and their responsibilities.&lt;/div&gt;&lt;br&gt;&lt;b&gt;Swimlane Summary&lt;/b&gt;&lt;div style='margin-top:6px;line-height:1.6'&gt;&lt;b&gt;• Patient&lt;/b&gt; — Arrives, fills registration form, waits, describes symptoms, collects prescription/results, and pays.&lt;br&gt;&lt;b&gt;• Receptionist&lt;/b&gt; — Checks appointment status, creates or updates patient records, assigns a queue number, and generates the final invoice.&lt;br&gt;&lt;b&gt;• Nurse&lt;/b&gt; — Calls the patient, records vitals (blood pressure, temperature, weight, height), and escorts the patient to the consultation room.&lt;br&gt;&lt;b&gt;• Doctor&lt;/b&gt; — Reviews the patient record and vitals, examines the patient, decides whether lab tests are needed, and writes a prescription and treatment plan.&lt;br&gt;&lt;b&gt;• Pharmacy / Lab&lt;/b&gt; — Dispenses medication for direct prescriptions, or runs diagnostic tests and returns results to the doctor for final prescription.&lt;/div&gt;" vertex="1">
          <mxGeometry x="40" y="1060" width="1380" height="220" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
